# Copy to a protected sandbox-only .env file. Use newly issued sandbox credentials only.
COMPOSE_PROJECT_NAME=nnviopp-sandbox
API_CONTAINER_NAME=nnviopp-sandbox-api
DB_CONTAINER_NAME=nnviopp-sandbox-mysql
ADMIN_CONTAINER_NAME=nnviopp-sandbox-admin
PAYMENT_NETWORK_NAME=nnviopp-sandbox_payment-net
MYSQL_VOLUME_NAME=nnviopp-sandbox_mysql-data
RECEIPT_VOLUME_NAME=nnviopp-sandbox_receipt-data
APP_ENV=sandbox
APP_PORT=8080
APP_BIND_HOST=127.0.0.1
APP_HOST_PORT=8181
ADMIN_BIND_HOST=127.0.0.1
ADMIN_HOST_PORT=8183
VITE_API_BASE_URL=https://sandbox-api.nnviopp.com
PUBLIC_BASE_URL=https://sandbox-api.nnviopp.com
MOCK_PROVIDER_ENABLED=false
TEST_DEPOSIT_CALLBACKS_ENABLED=true
HMAC_DIAGNOSTICS_ENABLED=false

MYSQL_ROOT_PASSWORD=<sandbox-root-password>
MYSQL_DATABASE=payment_sandbox
MYSQL_USER=payment_sandbox_app
MYSQL_PASSWORD=<sandbox-db-password>
DATABASE_DSN=payment_sandbox_app:<sandbox-db-password>@tcp(mysql:3306)/payment_sandbox?parseTime=true
MERCHANT_SECRET_ENCRYPTION_KEY=<sandbox-merchant-secret-encryption-key>
ADMIN_SESSION_SECRET=<sandbox-admin-session-secret-at-least-32-bytes>
ADMIN_INITIAL_USERNAME=<sandbox-admin-username>
ADMIN_INITIAL_PASSWORD_HASH=<sandbox-password-hash>
ADMIN_ALLOWED_ORIGINS=https://sandbox.nnviopp.com
ADMIN_COOKIE_DOMAIN=<sandbox-admin-cookie-domain-or-empty>
ADMIN_COOKIE_SAME_SITE=Lax

NEWEBPAY_ENV=sandbox
NEWEBPAY_MPG_URL=https://ccore.newebpay.com/MPG/mpg_gateway
NEWEBPAY_MERCHANT_ID=<sandbox-merchant-id>
NEWEBPAY_HASH_KEY=<sandbox-hash-key>
NEWEBPAY_HASH_IV=<sandbox-hash-iv>
NEWEBPAY_NOTIFY_URL=https://sandbox-api.nnviopp.com/api/v1/deposits/providers/newebpay/notifications
NEWEBPAY_RETURN_URL=https://sandbox-api.nnviopp.com/api/v1/deposits/payment-result

GATEWAY_BASE_URL=https://<sandbox-upstream-payout-provider-or-mock>
GATEWAY_CUSTOMER_ID=<sandbox-gateway-customer-id>
GATEWAY_HMAC_SECRET=<sandbox-gateway-hmac-secret>
GATEWAY_PREVIOUS_HMAC_SECRET=
GATEWAY_PAYOUT_NOTIFY_URL=https://sandbox-api.nnviopp.com/api/payments/callback
GATEWAY_DEPOSIT_CALLBACK_ALLOWLIST=<sandbox-provider-ip-or-cidr>
GATEWAY_PAYOUT_CALLBACK_ALLOWLIST=<sandbox-provider-ip-or-cidr>
GATEWAY_MAX_SKEW_SECONDS=300
GATEWAY_HTTP_TIMEOUT_SECONDS=15
MERCHANT_CODE=<sandbox-merchant-code>
MERCHANT_NAME=<sandbox-merchant-name>
MERCHANT_API_KEY=<sandbox-merchant-api-key>
MERCHANT_CALLBACK_SIGNING_KEY_ID=<sandbox-callback-key-id>
MERCHANT_CALLBACK_SIGNING_SECRET=<sandbox-callback-signing-secret>
MERCHANT_CALLBACK_URL=https://<sandbox-merchant-callback-host>/callback
MERCHANT_INITIAL_BALANCE_TWD=0
RECEIPT_STORAGE_PATH=/var/lib/payment-service/receipts
RECEIPT_MAX_SIZE_MB=10
CALLBACK_WORKER_INTERVAL=15
CALLBACK_MAX_ATTEMPTS=5
CALLBACK_TIMEOUT_SECONDS=10
APP_TRUSTED_PROXY_CIDRS=172.19.0.1/32
APP_READ_HEADER_TIMEOUT_SECONDS=10
APP_READ_TIMEOUT_SECONDS=15
APP_WRITE_TIMEOUT_SECONDS=30
APP_IDLE_TIMEOUT_SECONDS=60
APP_SHUTDOWN_TIMEOUT_SECONDS=15
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
WORKER_LEASE_SECONDS=45
PAYOUT_REVIEW_TOKEN=
PAYOUT_REVIEW_ACTOR_ALLOWLIST=
PAYOUT_REVIEW_ACTOR_ROLES=
