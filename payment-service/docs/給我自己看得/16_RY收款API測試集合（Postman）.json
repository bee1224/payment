    {
      "name": "收款 RY Contract",
      "item": [
        {
          "name": "收款-建立訂單 /api/pay_order",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function normalize(value) {",
                  "  if (value === null || value === undefined) return '';",
                  "  if (Array.isArray(value)) return JSON.stringify(value);",
                  "  return String(value).trim();",
                  "}",
                  "function isEmpty(value) {",
                  "  return value === null || value === undefined || value === '' || (Array.isArray(value) && value.length === 0);",
                  "}",
                  "function sign(fields, signKey) {",
                  "  const keys = Object.keys(fields).filter((key) => !isEmpty(fields[key])).sort();",
                  "  const parts = keys.map((key) => key + '=' + normalize(fields[key]));",
                  "  parts.push('key=' + signKey);",
                  "  return CryptoJS.MD5(parts.join('&')).toString().toUpperCase();",
                  "}",
                  "const now = Math.floor(Date.now() / 1000).toString();",
                  "const orderId = 'DEP' + new Date().toISOString().replace(/[-:TZ.]/g, '').slice(0, 14);",
                  "const bankAccounts = JSON.parse(pm.collectionVariables.get('bank_account_json') || '[]');",
                  "const storeNumbers = JSON.parse(pm.collectionVariables.get('store_number_json') || '[]');",
                  "pm.collectionVariables.set('pay_apply_date', now);",
                  "pm.collectionVariables.set('pay_order_id', orderId);",
                  "const fields = {",
                  "  pay_customer_id: pm.collectionVariables.get('pay_customer_id'),",
                  "  pay_apply_date: now,",
                  "  pay_order_id: orderId,",
                  "  pay_notify_url: pm.collectionVariables.get('pay_notify_url'),",
                  "  pay_amount: pm.collectionVariables.get('pay_amount'),",
                  "  pay_channel_id: pm.collectionVariables.get('pay_channel_id'),",
                  "  bank_account: bankAccounts,",
                  "  store_number: storeNumbers,",
                  "  pay_product_name: pm.collectionVariables.get('pay_product_name'),",
                  "  user_name: pm.collectionVariables.get('user_name'),",
                  "  bank_id: pm.collectionVariables.get('bank_id'),",
                  "  pay_currency: pm.collectionVariables.get('pay_currency'),",
                  "  mobile: pm.collectionVariables.get('mobile'),",
                  "  id_no: pm.collectionVariables.get('id_no')",
                  "};",
                  "pm.collectionVariables.set('pay_md5_sign', sign(fields, pm.collectionVariables.get('ry_sign_key')));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('code is 0', function () {",
                  "  pm.expect(json.code).to.eql(0);",
                  "});",
                  "if (json.data && json.data.order_id) pm.collectionVariables.set('pay_order_id', json.data.order_id);",
                  "if (json.data && json.data.transaction_id) pm.collectionVariables.set('transaction_id', json.data.transaction_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pay_customer_id\": \"{{pay_customer_id}}\",\n  \"pay_apply_date\": \"{{pay_apply_date}}\",\n  \"pay_order_id\": \"{{pay_order_id}}\",\n  \"pay_notify_url\": \"{{pay_notify_url}}\",\n  \"pay_amount\": \"{{pay_amount}}\",\n  \"pay_channel_id\": \"{{pay_channel_id}}\",\n  \"bank_account\": {{bank_account_json}},\n  \"store_number\": {{store_number_json}},\n  \"pay_product_name\": \"{{pay_product_name}}\",\n  \"user_name\": \"{{user_name}}\",\n  \"bank_id\": \"{{bank_id}}\",\n  \"pay_currency\": \"{{pay_currency}}\",\n  \"mobile\": \"{{mobile}}\",\n  \"id_no\": \"{{id_no}}\",\n  \"pay_md5_sign\": \"{{pay_md5_sign}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/pay_order",
              "host": ["{{base_url}}"],
              "path": ["api", "pay_order"]
            },
            "description": "Canonical deposit create route."
          }
        },
        {
          "name": "收款-查詢訂單 /api/query_transaction",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function normalize(value) {",
                  "  if (Array.isArray(value)) return JSON.stringify(value);",
                  "  return String(value).trim();",
                  "}",
                  "function sign(fields, signKey) {",
                  "  const keys = Object.keys(fields).sort();",
                  "  const parts = keys.map((key) => key + '=' + normalize(fields[key]));",
                  "  parts.push('key=' + signKey);",
                  "  return CryptoJS.MD5(parts.join('&')).toString().toUpperCase();",
                  "}",
                  "const now = Math.floor(Date.now() / 1000).toString();",
                  "const orderIds = [pm.collectionVariables.get('pay_order_id')];",
                  "pm.collectionVariables.set('query_apply_date', now);",
                  "pm.collectionVariables.set('query_md5_sign', sign({",
                  "  pay_customer_id: pm.collectionVariables.get('pay_customer_id'),",
                  "  pay_apply_date: now,",
                  "  pay_order_id: orderIds",
                  "}, pm.collectionVariables.get('ry_sign_key')));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('code is 0', function () {",
                  "  pm.expect(json.code).to.eql(0);",
                  "});",
                  "pm.test('data is array', function () {",
                  "  pm.expect(Array.isArray(json.data)).to.eql(true);",
                  "});",
                  "if (json.data && json.data.length > 0 && json.data[0].transaction_id) {",
                  "  pm.collectionVariables.set('transaction_id', json.data[0].transaction_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pay_customer_id\": \"{{pay_customer_id}}\",\n  \"pay_apply_date\": \"{{query_apply_date}}\",\n  \"pay_order_id\": [\n    \"{{pay_order_id}}\"\n  ],\n  \"pay_md5_sign\": \"{{query_md5_sign}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/query_transaction",
              "host": ["{{base_url}}"],
              "path": ["api", "query_transaction"]
            },
            "description": "Canonical deposit query route."
          }
        }
      ]
