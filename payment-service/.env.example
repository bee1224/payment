COMPOSE_PROJECT_NAME=payment
APP_ENV=production
APP_PORT=8080
MERCHANT_SECRET_ENCRYPTION_KEY=change_me_merchant_secret_encryption_key
APP_BIND_HOST=127.0.0.1
APP_HOST_PORT=8080
ADMIN_BIND_HOST=127.0.0.1
ADMIN_HOST_PORT=8081
VITE_API_BASE_URL=http://localhost:8080
DATABASE_DSN=payment_app:change_me_app_password@tcp(mysql:3306)/payment_service?parseTime=true

MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=payment_service
MYSQL_USER=payment_app
MYSQL_PASSWORD=change_me_app_password

NEWEBPAY_MPG_URL=https://core.newebpay.com/MPG/mpg_gateway
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_NOTIFY_URL=https://api.nnviopp.com/api/v1/deposits/providers/newebpay/notifications
NEWEBPAY_RETURN_URL=https://api.nnviopp.com/api/v1/deposits/payment-result

GATEWAY_BASE_URL=https://upstream-payout-provider.example
GATEWAY_CUSTOMER_ID=RIG001
GATEWAY_HMAC_SECRET=change_me_gateway_hmac_secret
GATEWAY_PREVIOUS_HMAC_SECRET=
GATEWAY_PAYOUT_NOTIFY_URL=https://api.nnviopp.com/api/payments/callback
GATEWAY_DEPOSIT_CALLBACK_ALLOWLIST=35.220.239.87,159.198.40.128
GATEWAY_PAYOUT_CALLBACK_ALLOWLIST=35.220.239.87,159.198.40.128
GATEWAY_MAX_SKEW_SECONDS=300
GATEWAY_HTTP_TIMEOUT_SECONDS=15

MERCHANT_CODE=RIG001
MERCHANT_NAME=NewebPay
MERCHANT_API_KEY=
MERCHANT_CALLBACK_SIGNING_KEY_ID=<merchant-callback-key-id>
MERCHANT_CALLBACK_SIGNING_SECRET=<merchant-callback-signing-secret>
MERCHANT_CALLBACK_URL=
MERCHANT_INITIAL_BALANCE_TWD=0

ADMIN_SESSION_SECRET=replace_with_at_least_32_random_bytes
ADMIN_INITIAL_USERNAME=admin
# pbkdf2-sha256:<iterations>:<salt hex>:<derived key hex>; use the bootstrap command documented in docs/admin-payout-console.md
ADMIN_INITIAL_PASSWORD_HASH=
RECEIPT_STORAGE_PATH=/var/lib/payment-service/receipts
RECEIPT_MAX_SIZE_MB=10
CALLBACK_WORKER_INTERVAL=15
CALLBACK_MAX_ATTEMPTS=5
CALLBACK_TIMEOUT_SECONDS=10
ADMIN_ALLOWED_ORIGINS=https://admin.nnviopp.com
ADMIN_COOKIE_DOMAIN=
ADMIN_COOKIE_SAME_SITE=Lax
APP_TRUSTED_PROXY_CIDRS=
APP_READ_HEADER_TIMEOUT_SECONDS=10
APP_READ_TIMEOUT_SECONDS=15
APP_WRITE_TIMEOUT_SECONDS=30
APP_IDLE_TIMEOUT_SECONDS=60
APP_SHUTDOWN_TIMEOUT_SECONDS=15
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
WORKER_LEASE_SECONDS=45
# Disabled by default. When true, an MFA-authenticated ADMIN may send a one-off
# test deposit success callback without changing the order or ledger.
TEST_DEPOSIT_CALLBACKS_ENABLED=false
HMAC_DIAGNOSTICS_ENABLED=false
