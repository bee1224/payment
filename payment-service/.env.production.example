# Copy to a protected production-only .env file. Never copy its values into sandbox.
COMPOSE_PROJECT_NAME=nnviopp-production
API_CONTAINER_NAME=payment-api-prod
DB_CONTAINER_NAME=payment-db-prod
ADMIN_CONTAINER_NAME=payment-admin-prod
PAYMENT_NETWORK_NAME=nnviopp-prod-network
MYSQL_VOLUME_NAME=nnviopp-prod-mysql-data
RECEIPT_VOLUME_NAME=nnviopp-prod-receipt-data
APP_ENV=production
APP_PORT=8080
APP_BIND_HOST=127.0.0.1
APP_HOST_PORT=8080
ADMIN_BIND_HOST=127.0.0.1
ADMIN_HOST_PORT=8082
VITE_API_BASE_URL=https://api.nnviopp.com
PUBLIC_BASE_URL=https://api.nnviopp.com
MOCK_PROVIDER_ENABLED=false
TEST_DEPOSIT_CALLBACKS_ENABLED=false
HMAC_DIAGNOSTICS_ENABLED=false

MYSQL_ROOT_PASSWORD=<production-root-password>
MYSQL_DATABASE=payment_production
MYSQL_USER=payment_production_app
MYSQL_PASSWORD=<production-db-password>
DATABASE_DSN=payment_production_app:<production-db-password>@tcp(mysql:3306)/payment_production?parseTime=true
MERCHANT_SECRET_ENCRYPTION_KEY=<production-merchant-secret-encryption-key>
ADMIN_SESSION_SECRET=<production-admin-session-secret-at-least-32-bytes>
ADMIN_INITIAL_USERNAME=<production-admin-username>
ADMIN_INITIAL_PASSWORD_HASH=<production-password-hash>
ADMIN_ALLOWED_ORIGINS=https://admin.nnviopp.com
ADMIN_COOKIE_DOMAIN=<production-admin-cookie-domain-or-empty>
ADMIN_COOKIE_SAME_SITE=Lax

NEWEBPAY_ENV=production
NEWEBPAY_MPG_URL=https://core.newebpay.com/MPG/mpg_gateway
NEWEBPAY_MERCHANT_ID=<production-merchant-id>
NEWEBPAY_HASH_KEY=<production-hash-key>
NEWEBPAY_HASH_IV=<production-hash-iv>
NEWEBPAY_NOTIFY_URL=https://api.nnviopp.com/api/v1/deposits/providers/newebpay/notifications
NEWEBPAY_RETURN_URL=https://api.nnviopp.com/api/v1/deposits/payment-result

GATEWAY_BASE_URL=https://<production-upstream-payout-provider>
GATEWAY_CUSTOMER_ID=<production-gateway-customer-id>
GATEWAY_HMAC_SECRET=<production-gateway-hmac-secret>
GATEWAY_PREVIOUS_HMAC_SECRET=
GATEWAY_PAYOUT_NOTIFY_URL=https://api.nnviopp.com/api/payments/callback
GATEWAY_DEPOSIT_CALLBACK_ALLOWLIST=<production-provider-ip-or-cidr>
GATEWAY_PAYOUT_CALLBACK_ALLOWLIST=<production-provider-ip-or-cidr>
GATEWAY_MAX_SKEW_SECONDS=300
GATEWAY_HTTP_TIMEOUT_SECONDS=15
MERCHANT_CODE=<production-merchant-code>
MERCHANT_NAME=<production-merchant-name>
MERCHANT_API_KEY=<production-merchant-api-key>
MERCHANT_CALLBACK_SIGNING_KEY_ID=<production-callback-key-id>
MERCHANT_CALLBACK_SIGNING_SECRET=<production-callback-signing-secret>
MERCHANT_CALLBACK_URL=https://<production-merchant-callback-host>/callback
MERCHANT_INITIAL_BALANCE_TWD=0
RECEIPT_STORAGE_PATH=/var/lib/payment-service/receipts
RECEIPT_MAX_SIZE_MB=10
CALLBACK_WORKER_INTERVAL=15
CALLBACK_MAX_ATTEMPTS=5
CALLBACK_TIMEOUT_SECONDS=10
APP_TRUSTED_PROXY_CIDRS=<production-nginx-or-load-balancer-cidr>
APP_READ_HEADER_TIMEOUT_SECONDS=10
APP_READ_TIMEOUT_SECONDS=15
APP_WRITE_TIMEOUT_SECONDS=30
APP_IDLE_TIMEOUT_SECONDS=60
APP_SHUTDOWN_TIMEOUT_SECONDS=15
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
WORKER_LEASE_SECONDS=45
PAYOUT_REVIEW_TOKEN=
PAYOUT_REVIEW_ACTOR_ALLOWLIST=
PAYOUT_REVIEW_ACTOR_ROLES=
