# 僅供本機 Docker 開發；不可用於 Sandbox 或 Production。
COMPOSE_PROJECT_NAME=payment-development
APP_ENV=local
APP_PORT=8080
APP_BIND_HOST=127.0.0.1
APP_HOST_PORT=8080
ADMIN_BIND_HOST=127.0.0.1
ADMIN_HOST_PORT=8081
VITE_API_BASE_URL=http://127.0.0.1:8080

MYSQL_ROOT_PASSWORD=replace_with_local_root_password
MYSQL_DATABASE=payment_development
MYSQL_USER=payment_development_app
MYSQL_PASSWORD=replace_with_local_app_password
DATABASE_DSN=payment_development_app:replace_with_local_app_password@tcp(mysql:3306)/payment_development?parseTime=true

PUBLIC_BASE_URL=https://payment-development.invalid
MOCK_PROVIDER_ENABLED=true
TEST_DEPOSIT_CALLBACKS_ENABLED=false
NEWEBPAY_ENV=local
NEWEBPAY_MPG_URL=https://mock-newebpay.invalid/MPG/mpg_gateway
NEWEBPAY_MERCHANT_ID=development_merchant
NEWEBPAY_HASH_KEY=development_only_hash_key
NEWEBPAY_HASH_IV=development_only_hash_iv
NEWEBPAY_NOTIFY_URL=https://payment-development.invalid/api/v1/deposits/providers/newebpay/notifications
NEWEBPAY_RETURN_URL=https://payment-development.invalid/api/v1/deposits/payment-result

GATEWAY_BASE_URL=https://mock-gateway.invalid
GATEWAY_CUSTOMER_ID=development_customer
GATEWAY_HMAC_SECRET=development_only_gateway_hmac_secret
GATEWAY_PREVIOUS_HMAC_SECRET=
GATEWAY_PAYOUT_NOTIFY_URL=https://payment-development.invalid/api/payments/callback
GATEWAY_DEPOSIT_CALLBACK_ALLOWLIST=198.51.100.10
GATEWAY_PAYOUT_CALLBACK_ALLOWLIST=198.51.100.10
GATEWAY_MAX_SKEW_SECONDS=300
GATEWAY_HTTP_TIMEOUT_SECONDS=15

MERCHANT_CODE=DEVELOPMENT_MERCHANT
MERCHANT_NAME=Local Development Merchant
MERCHANT_API_KEY=development_only_merchant_api_key
MERCHANT_CALLBACK_SIGNING_KEY_ID=dev-callback-v1
MERCHANT_CALLBACK_SIGNING_SECRET=development_only_callback_signing_secret
MERCHANT_CALLBACK_URL=
MERCHANT_INITIAL_BALANCE_TWD=100000
MERCHANT_SECRET_ENCRYPTION_KEY=replace_with_a_local_32_byte_minimum_secret

# 建立本機 .env.development 時自行產生，勿提交。
ADMIN_SESSION_SECRET=replace_with_a_local_32_byte_minimum_secret
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD_HASH=
ADMIN_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:8081
ADMIN_COOKIE_DOMAIN=
ADMIN_COOKIE_SAME_SITE=Lax

RECEIPT_STORAGE_PATH=/var/lib/payment-service/receipts
RECEIPT_MAX_SIZE_MB=10
CALLBACK_WORKER_INTERVAL=15
CALLBACK_MAX_ATTEMPTS=5
CALLBACK_TIMEOUT_SECONDS=10
APP_TRUSTED_PROXY_CIDRS=
APP_READ_HEADER_TIMEOUT_SECONDS=10
APP_READ_TIMEOUT_SECONDS=15
APP_WRITE_TIMEOUT_SECONDS=30
APP_IDLE_TIMEOUT_SECONDS=60
APP_SHUTDOWN_TIMEOUT_SECONDS=15
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
WORKER_LEASE_SECONDS=45
PAYOUT_REVIEW_TOKEN=
PAYOUT_REVIEW_ACTOR_ALLOWLIST=
PAYOUT_REVIEW_ACTOR_ROLES=
