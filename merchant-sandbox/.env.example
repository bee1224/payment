# Sandbox only. Never use Production URLs, IDs, API keys, or secrets here.
PAYMENT_SANDBOX_BASE_URL=https://sandbox-api.nnviopp.com
PAYMENT_CUSTOMER_ID=<sandbox-customer-id>
PAYMENT_CUSTOMER_SECRET=<sandbox-customer-hmac-secret>
PAYMENT_MERCHANT_ID=<sandbox-merchant-id>
PAYMENT_MERCHANT_SECRET=<sandbox-merchant-hmac-secret>
PAYMENT_API_KEY=<sandbox-payout-api-key>
MERCHANT_SANDBOX_CALLBACK_KEY_ID=<sandbox-callback-key-id>
MERCHANT_SANDBOX_CALLBACK_SIGNING_SECRET=<sandbox-callback-signing-secret>

MERCHANT_SANDBOX_LISTEN_ADDR=:8081
MERCHANT_SANDBOX_CALLBACK_PATH=/callbacks/payment
MERCHANT_SANDBOX_CALLBACK_RESPONSE_MODE=success
# Set this higher than the platform callback timeout only in a controlled timeout test.
MERCHANT_SANDBOX_TIMEOUT_DELAY=35s
MERCHANT_SANDBOX_RECORDS_PATH=var/callback-records.jsonl
